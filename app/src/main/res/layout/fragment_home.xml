<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5DC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ನಮ್ಮ ಶಾಸನೆ"
            android:textAlignment="center"
            android:textColor="#8B4513"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Namma Shasane"
            android:textAlignment="center"
            android:textColor="#DAA520"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:layout_marginBottom="24dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <!-- Find Shasane Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFindShasane"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFE4B5">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_search" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Find Shasane"
                        android:textColor="#8B4513"
                        android:fontFamily="serif" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Photo Tag Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPhotoTag"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFE4B5">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_camera" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Photo Tag"
                        android:textColor="#8B4513"
                        android:fontFamily="serif" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- AI Decode Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAIDecode"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFE4B5">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_edit" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI Decode"
                        android:textColor="#8B4513"
                        android:fontFamily="serif" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- History Quiz Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardHistoryQuiz"
                android:layout_width="0dp"
                android:layout_height="120dp"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFE4B5">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_help" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="History Quiz"
                        android:textColor="#8B4513"
                        android:fontFamily="serif" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recent Discoveries"
            android:textColor="#8B4513"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:fontFamily="serif" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recent_discoveries_recycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="“ಹಳೆಯ ಕಲ್ಲುಗಳು ಮಾತನಾಡುತ್ತವೆ”\n(Old stones speak)"
            android:textAlignment="center"
            android:textColor="#8B4513"
            android:textSize="16sp"
            android:textStyle="italic"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="32dp"
            android:fontFamily="serif" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
